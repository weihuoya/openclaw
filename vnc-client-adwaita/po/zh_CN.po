#: data/com.weiz.vnc-client-adwaita.gschema.xml
msgid "Last VNC host"
msgstr "上次 VNC 主机"

#: data/com.weiz.vnc-client-adwaita.gschema.xml
msgid "Hostname or IP address of the last VNC server."
msgstr "上次 VNC 服务器的主机名或 IP 地址。"

#: data/com.weiz.vnc-client-adwaita.gschema.xml
msgid "Last VNC port"
msgstr "上次 VNC 端口"

#: data/com.weiz.vnc-client-adwaita.gschema.xml
msgid "TCP port of the last VNC server."
msgstr "上次 VNC 服务器的 TCP 端口。"

#: data/com.weiz.vnc-client-adwaita.gschema.xml
msgid "Username for SASL/VeNCrypt"
msgstr "SASL/VeNCrypt 用户名"

#: data/com.weiz.vnc-client-adwaita.gschema.xml
msgid "Username used by authentication methods that require it."
msgstr "需要用户名时使用的认证用户名。"

#: data/com.weiz.vnc-client-adwaita.gschema.xml
msgid "Either 'none' or 'password'."
msgstr "可以是 'none' 或 'password'。"

#: data/com.weiz.vnc-client-adwaita.gschema.xml
msgid "Preferred VNC encoding"
msgstr "首选 VNC 编码"

#: data/com.weiz.vnc-client-adwaita.gschema.xml
msgid "Encoding requested first. Supported: zrle, hextile, raw, copyrect, trle, rre, tight, openh264."
msgstr "优先请求的编码。支持：zrle、hextile、raw、copyrect、trle、rre、tight、openh264。"

#: data/com.weiz.vnc-client-adwaita.gschema.xml
msgid "Do not send mouse or keyboard events to the server."
msgstr "不向服务器发送鼠标或键盘事件。"

#: data/com.weiz.vnc-client-adwaita.gschema.xml
msgid "Scale the remote desktop to fit the window."
msgstr "将远程桌面缩放以适应窗口。"

#: data/com.weiz.vnc-client-adwaita.desktop.in
msgid "A simple VNC client built with libadwaita and GTK4"
msgstr "基于 libadwaita 和 GTK4 的简洁 VNC 客户端"
