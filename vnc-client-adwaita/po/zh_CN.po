#: src/main.rs
msgid "GSettings schema '{}' not found."
msgstr "找不到 GSettings 配置 '{}'。"

#: src/main.rs
msgid "Compile it with: glib-compile-schemas vnc-client-adwaita/data/"
msgstr "使用以下命令编译：glib-compile-schemas vnc-client-adwaita/data/"

#: src/main.rs
msgid "Run with: GSETTINGS_SCHEMA_DIR=vnc-client-adwaita/data cargo run -p vnc-client-adwaita"
msgstr "运行方式：GSETTINGS_SCHEMA_DIR=vnc-client-adwaita/data cargo run -p vnc-client-adwaita"

